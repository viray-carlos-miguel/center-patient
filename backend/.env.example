# PostgreSQL Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medical_education_db

# Application Settings
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-for-educational-purposes-only
API_PREFIX=/api
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Educational Platform Settings
PLATFORM_NAME=Medical Education Platform
PLATFORM_VERSION=1.0.0
EDUCATIONAL_MODE=True

# Email Configuration (Gmail SMTP)
GMAIL_EMAIL=medical.center.pro.demo@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=medical_center

# ChatGPT API (used as fallback when ML urgency classifier confidence is low)
CHATGPT_API_KEY=sk-your-openai-api-key-here
CHATGPT_MODEL=gpt-4o